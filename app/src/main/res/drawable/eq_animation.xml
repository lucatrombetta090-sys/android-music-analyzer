<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    <!-- Frame 1: bars low-mid-high -->
    <item android:duration="120">
        <layer-list>
            <item android:left="0dp" android:right="8dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="8dp"/>
                </shape>
            </item>
            <item android:left="5dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="14dp"/>
                </shape>
            </item>
            <item android:left="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="6dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Frame 2 -->
    <item android:duration="120">
        <layer-list>
            <item android:left="0dp" android:right="8dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="14dp"/>
                </shape>
            </item>
            <item android:left="5dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="6dp"/>
                </shape>
            </item>
            <item android:left="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="12dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Frame 3 -->
    <item android:duration="120">
        <layer-list>
            <item android:left="0dp" android:right="8dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="12dp"/>
                </shape>
            </item>
            <item android:left="5dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="8dp"/>
                </shape>
            </item>
            <item android:left="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1DB954"/>
                    <size android:width="3dp" android:height="14dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</animation-list>
