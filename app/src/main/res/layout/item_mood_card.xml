<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/moodCard"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="4dp"
    android:paddingBottom="8dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Album art quadrata grande con angoli arrotondati -->
    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/cardArt"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:background="@color/elevated"
            android:visibility="invisible"
            app:shapeAppearanceOverlay="@style/RoundedImageLarge"/>

        <TextView
            android:id="@+id/cardLetter"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:gravity="center"
            android:textSize="52sp"
            android:textStyle="bold"
            android:textColor="#535353"
            android:background="@drawable/rounded_art_bg_large"
            android:text="♪"/>

        <!-- Mood dot nell'angolo in basso a destra -->
        <View
            android:id="@+id/cardMoodDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:background="@drawable/mood_dot"
            android:visibility="gone"/>
    </FrameLayout>

    <TextView
        android:id="@+id/cardTitle"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/cardArtist"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/subtext"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:layout_marginTop="2dp"/>
</LinearLayout>
